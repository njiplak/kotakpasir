# kotakpasir — environment configuration
# Copy to .env and adjust. Flags on kpd/kpmcp override these at runtime.
#
# This file holds OPS / CONNECTION knobs only.
# Sandbox policy (image allowlist, profiles, egress) lives in kotakpasir.yaml.

# ── Server (kpd) ──────────────────────────────────────────────
KPD_ADDR=:8080
# Leave empty to disable auth (open access). Set to require: Authorization: Bearer <token>
KPD_TOKEN=
KPD_SHUTDOWN_TIMEOUT=15s
# debug | info | warn | error
KPD_LOG_LEVEL=info

# ── Storage ───────────────────────────────────────────────────
KPD_DB=./kotakpasir.db

# ── Reaper (TTL GC) ───────────────────────────────────────────
# How often to scan for expired sandboxes. Set to 0 to disable.
KP_REAPER_INTERVAL=30s

# ── Logs ──────────────────────────────────────────────────────
# Per-sandbox bound on captured exec output (bytes). Older entries are
# evicted FIFO. Set to 0 to disable capture entirely (kp logs returns empty).
KP_LOG_BUFFER_BYTES=262144

# ── Policy ────────────────────────────────────────────────────
# Path to the YAML policy file (image allowlist, profiles, egress).
# Empty or missing file = permissive defaults.
KP_POLICY_FILE=./kotakpasir.yaml
# Strict mode: refuse to start unless KP_POLICY_FILE points at a readable file.
# Set this in prod so a misplaced policy file can't silently fall back to permissive defaults.
KP_REQUIRE_POLICY=0

# ── Docker client (read by github.com/docker/docker/client.FromEnv) ──
# Override only if your daemon socket isn't the default.
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_API_VERSION=1.45
